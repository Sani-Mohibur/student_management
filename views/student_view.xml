<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="student_view_tree" model="ir.ui.view">
        <field name="name">student.management.student.tree</field>
        <field name="model">student.management.student</field>
        <field name="arch" type="xml">
            <tree string="Students">
                <field name="name"/>
                <field name="roll_no"/>
                <field name="department"/>
            </tree>
        </field>
    </record>

    <record id="student_view_form" model="ir.ui.view">
        <field name="name">student.management.student.form</field>
        <field name="model">student.management.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <button name="action_show_enrolled_courses" type="object" string="Show Enrolled Courses" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="roll_no"/>
                        <field name="department"/>
                    </group>
                    <notebook>
                        <page string="Enrolled Courses">
                            <field name="course_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student.management.student</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            Click to create a new student.
            </p>
        </field>
    </record>

    <menuitem id="menu_student_management_root" name="Student Management" sequence="10"/>

    <menuitem id="menu_student" name="Students" parent="menu_student_management_root" action="action_student" sequence="10"/>

</odoo>